// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  fullName     String
  avatarDataUrl String?
  sex          String?
  age          Int?
  heightCm     Float?
  weightKg     Float?
  targetWeightKg Float?
  timeframeWeeks Int?
  trainingDaysPerWeek Int?
  trainingGoal String?
  preferredTrainingEnvironment String?
  experienceLevel String?
  limitations  String[] @default([])
  onboardingCompletedAt DateTime?
  remindersEnabled Boolean @default(true)
  reminderTime String?
  reminderWorkout Boolean @default(true)
  reminderNutrition Boolean @default(true)
  reminderWeeklyReview Boolean @default(true)
  reminderReactivation Boolean @default(true)
  socialProfileVisibility String @default("public")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones - Fitness
  workouts     Workout[]
  sessions     WorkoutSession[]
  measurements BodyMeasurement[]

  // Relaciones - Nutrición
  mealPlans        MealPlan[]
  recipes          Recipe[]
  nutritionLogs    NutritionLog[]
  nutritionBalance UserNutritionBalance?
  foodItems        FoodItem[]
  mealLogs         MealLog[]
  nutritionTarget  NutritionTarget?
  healthDataImports HealthDataImport[]
  wearableConnections WearableConnection[]
  recoverySamples RecoverySample[]

  // Relaciones - Gamificación
  gamification    UserGamification?
  achievements    UserAchievement[]
  xpEvents        XPEvent[]
  productEvents   ProductEvent[]
  notificationDeliveries NotificationDelivery[]
  personalRecords PersonalRecord[]
  muscleVolumes   MuscleVolume[]
  progressionStates ExerciseProgressionState[]
  coachConversations CoachConversation[]
  coachUsageWindows CoachUsageWindow[]
  following Follow[] @relation("FollowFollower")
  followers Follow[] @relation("FollowFollowing")
  activityFeedItems ActivityFeedItem[]
  kudos Kudos[]
  challengeParticipants ChallengeParticipant[]

  @@map("users")
}

model Exercise {
  id           String   @id @default(uuid())
  name         String
  category     String
  muscleGroup  String
  equipment    String
  trainingEnvironments String[] @default([])
  difficulty   String
  description  String
  instructions String[]
  imageUrl     String?  // URL de la imagen/GIF del ejercicio
  videoUrl     String?  // URL de video tutorial (opcional)
  editorialOverrideStatus String?
  editorialNotes String?
  editorialReviewedAt DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relaciones
  workoutExercises WorkoutExercise[]
  sessionExercises SessionExercise[]
  personalRecords PersonalRecord[]
  progressionStates ExerciseProgressionState[]

  @@index([category])
  @@index([muscleGroup])
  @@index([equipment])
  @@index([difficulty])
  @@map("exercises")
}

model Workout {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercises WorkoutExercise[]
  sessions  WorkoutSession[]

  @@index([userId])
  @@map("workouts")
}

model WorkoutExercise {
  id         String @id @default(uuid())
  workoutId  String
  exerciseId String
  sets       Int
  reps       Int
  rest       Int // segundos
  order      Int // orden en el workout

  // Relaciones
  workout  Workout  @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([workoutId, order])
  @@index([workoutId])
  @@index([exerciseId])
  @@map("workout_exercises")
}

model WorkoutSession {
  id          String   @id @default(uuid())
  userId      String
  workoutId   String
  completedAt DateTime @default(now())
  duration    Int // segundos
  notes       String?

  // Relaciones
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  workout   Workout           @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercises SessionExercise[]
  muscleVolumes MuscleVolume[]

  @@index([userId])
  @@index([workoutId])
  @@index([completedAt])
  @@map("workout_sessions")
}

model SessionExercise {
  id         String @id @default(uuid())
  sessionId  String
  exerciseId String

  // Relaciones
  session  WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  exercise Exercise       @relation(fields: [exerciseId], references: [id], onDelete: Cascade)
  sets     SessionSet[]

  @@index([sessionId])
  @@index([exerciseId])
  @@map("session_exercises")
}

model SessionSet {
  id                String  @id @default(uuid())
  sessionExerciseId String
  reps              Int
  weight            Float // kg
  rir               Int?
  rpe               Float?
  restSeconds       Int?
  order             Int

  // Relaciones
  sessionExercise SessionExercise @relation(fields: [sessionExerciseId], references: [id], onDelete: Cascade)

  @@index([sessionExerciseId])
  @@map("session_sets")
}

model PersonalRecord {
  id                      String   @id @default(uuid())
  userId                  String
  exerciseId              String
  maxWeight               Float
  bestEstimatedOneRepMax  Float
  reps                    Int
  weight                  Float
  achievedAt              DateTime
  updatedAt               DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
  @@index([userId])
  @@index([exerciseId])
  @@index([achievedAt])
  @@map("personal_records")
}

model MuscleVolume {
  id          String   @id @default(uuid())
  userId      String
  sessionId   String
  muscleGroup String
  totalVolume Float
  setCount     Int
  createdAt   DateTime @default(now())

  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  session WorkoutSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, muscleGroup])
  @@index([userId])
  @@index([muscleGroup])
  @@index([createdAt])
  @@map("muscle_volumes")
}

model ExerciseProgressionState {
  id                     String   @id @default(uuid())
  userId                 String
  exerciseId             String
  currentWeight          Float
  targetMinReps          Int
  targetMaxReps          Int
  lastSessionReps        Int[]    @default([])
  lastSessionRIR         Float?
  consecutiveSuccesses   Int      @default(0)
  consecutiveStalls      Int      @default(0)
  lastTrainedAt          DateTime?
  strategy               String   @default("LINEAR")
  deloadActive           Boolean  @default(false)
  lastDeloadAt           DateTime?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
  @@index([userId])
  @@index([exerciseId])
  @@index([lastTrainedAt])
  @@map("exercise_progression_states")
}

model CoachConversation {
  id        String   @id @default(uuid())
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages CoachMessage[]

  @@index([userId])
  @@index([updatedAt])
  @@map("coach_conversations")
}

model CoachMessage {
  id             String   @id @default(uuid())
  conversationId String
  role           String
  content        String
  provider       String?
  model          String?
  estimatedTokens Int     @default(0)
  safetyFlags    String[] @default([])
  createdAt      DateTime @default(now())

  conversation CoachConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@index([createdAt])
  @@map("coach_messages")
}

model CoachUsageWindow {
  id             String   @id @default(uuid())
  userId         String
  windowStartsAt DateTime
  requestCount   Int      @default(0)
  tokenEstimate  Int      @default(0)
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, windowStartsAt])
  @@index([userId])
  @@index([windowStartsAt])
  @@map("coach_usage_windows")
}

model Follow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower  User @relation("FollowFollower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("FollowFollowing", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
  @@map("follows")
}

model ActivityFeedItem {
  id         String   @id @default(uuid())
  userId     String
  type       String
  content    String
  sourceType String?
  sourceId   String?
  visibility String   @default("public")
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user  User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  kudos Kudos[]

  @@index([userId])
  @@index([type])
  @@index([visibility])
  @@index([createdAt])
  @@map("activity_feed_items")
}

model Kudos {
  id         String   @id @default(uuid())
  userId     String
  feedItemId String
  createdAt  DateTime @default(now())

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  feedItem ActivityFeedItem @relation(fields: [feedItemId], references: [id], onDelete: Cascade)

  @@unique([userId, feedItemId])
  @@index([userId])
  @@index([feedItemId])
  @@map("kudos")
}

model Challenge {
  id        String   @id @default(uuid())
  key       String   @unique
  title     String
  metric    String
  startsAt  DateTime
  endsAt    DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants ChallengeParticipant[]

  @@index([startsAt])
  @@index([endsAt])
  @@map("challenges")
}

model ChallengeParticipant {
  id          String   @id @default(uuid())
  challengeId String
  userId      String
  score       Int      @default(0)
  joinedAt    DateTime @default(now())
  updatedAt   DateTime @updatedAt

  challenge Challenge @relation(fields: [challengeId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([challengeId, userId])
  @@index([challengeId])
  @@index([userId])
  @@map("challenge_participants")
}

model BodyMeasurement {
  id      String   @id @default(uuid())
  userId  String
  date    DateTime @default(now())
  weight  Float? // kg
  bodyFat Float? // porcentaje
  chest   Float? // cm
  waist   Float? // cm
  hips    Float? // cm
  arms    Float? // cm
  thighs  Float? // cm

  // Relaciones
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@map("body_measurements")
}

// ==========================================
// MODELOS DE NUTRICIÓN
// ==========================================

model MealPlan {
  id        String   @id @default(uuid())
  userId    String
  weekStart DateTime
  goal      String?  // ej. "perdida_peso", "ganancia_muscular", "mantenimiento"
  dietType  String?  // "ninguna", "mediterranea", "dash", "ayuno_intermitente"
  carryoverCaloriesApplied Float @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relaciones
  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  meals Meal[]

  @@index([userId])
  @@index([weekStart])
  @@map("meal_plans")
}

model Meal {
  id                String @id @default(uuid())
  mealPlanId        String
  dayOfWeek         Int    // 0=Lunes, 6=Domingo
  mealType          String // "desayuno", "almuerzo", "cena", "snack"
  servingMultiplier Float @default(1)
  adjustmentReason  String?
  selectedRecipeId  String?

  // Relaciones
  mealPlan       MealPlan          @relation(fields: [mealPlanId], references: [id], onDelete: Cascade)
  selectedRecipe Recipe?           @relation("SelectedMealRecipe", fields: [selectedRecipeId], references: [id], onDelete: SetNull)
  recipes        MealRecipe[]
  swapHistory    MealSwapHistory[]

  @@index([mealPlanId])
  @@index([selectedRecipeId])
  @@map("meals")
}

model Recipe {
  id                      String   @id @default(uuid())
  userId                  String?
  name                    String
  nameEn                  String?
  description             String?
  instructions            Json     // array de pasos como JSON
  prepTime                Int?     // minutos
  cookTime                Int?     // minutos
  servings                Int      @default(1)
  difficulty              String?  // "facil", "medio", "dificil"
  calories                Float?
  protein                 Float?   // gramos
  carbs                   Float?   // gramos
  fat                     Float?   // gramos
  fiber                   Float?   // gramos
  imageUrl                String?
  tags                    String[]
  source                  String   @default("system") // "system" | "ai" | "user"
  isPublic                Boolean  @default(true)
  isEditable              Boolean  @default(false)
  mealTypes               String[] @default([])
  dietTypes               String[] @default([])
  goalTypes               String[] @default([])
  editorialOverrideStatus String?
  editorialNotes          String?
  editorialReviewedAt     DateTime?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  // Relaciones
  user            User?             @relation(fields: [userId], references: [id], onDelete: SetNull)
  meals           MealRecipe[]
  selectedInMeals Meal[]            @relation("SelectedMealRecipe")
  ingredients     RecipeIngredient[]
  previousSwaps   MealSwapHistory[] @relation("PreviousRecipeSwap")
  newSwaps        MealSwapHistory[] @relation("NewRecipeSwap")

  @@index([userId])
  @@index([source])
  @@index([isPublic])
  @@map("recipes")
}

model Ingredient {
  id      String @id @default(uuid())
  name    String @unique
  nameEn  String?
  unit    String // "g", "ml", "unidad", etc.

  // Relaciones
  recipes RecipeIngredient[]

  @@map("ingredients")
}

model RecipeIngredient {
  id           String @id @default(uuid())
  recipeId     String
  ingredientId String
  quantity     Float

  // Relaciones
  recipe     Recipe     @relation(fields: [recipeId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@unique([recipeId, ingredientId])
  @@index([recipeId])
  @@map("recipe_ingredients")
}

model MealRecipe {
  id       String @id @default(uuid())
  mealId   String
  recipeId String

  // Relaciones
  meal   Meal   @relation(fields: [mealId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@index([mealId])
  @@index([recipeId])
  @@map("meal_recipes")
}

model MealSwapHistory {
  id               String   @id @default(uuid())
  mealId           String
  previousRecipeId String?
  newRecipeId      String?
  swapSource       String   @default("user") // "user" | "ai" | "system"
  reason           String?
  createdAt        DateTime @default(now())

  // Relaciones
  meal           Meal    @relation(fields: [mealId], references: [id], onDelete: Cascade)
  previousRecipe Recipe? @relation("PreviousRecipeSwap", fields: [previousRecipeId], references: [id], onDelete: SetNull)
  newRecipe      Recipe? @relation("NewRecipeSwap", fields: [newRecipeId], references: [id], onDelete: SetNull)

  @@index([mealId])
  @@index([createdAt])
  @@map("meal_swap_history")
}

model NutritionLog {
  id       String   @id @default(uuid())
  userId   String
  date     DateTime @default(now())
  consumedAt DateTime?
  mealType String   // "desayuno", "almuerzo", "cena", "snack"
  recipeId String?
  name     String?  // nombre libre si no es receta
  calories Float
  protein  Float
  carbs    Float
  fat      Float
  notes    String?
  createdAt DateTime @default(now())

  // Relaciones
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([date])
  @@index([mealType])
  @@map("nutrition_logs")
}

model FoodItem {
  id           String   @id @default(uuid())
  userId       String?
  name         String
  brand        String?
  barcode      String?
  servingSizeG Float
  calories     Float
  protein      Float
  carbs        Float
  fat          Float
  fiber        Float   @default(0)
  source       String  @default("user")
  verified     Boolean @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
  mealLogs MealLog[]

  @@index([userId])
  @@index([name])
  @@index([barcode])
  @@map("food_items")
}

model MealLog {
  id        String   @id @default(uuid())
  userId    String
  foodItemId String?
  mealType  String
  consumedAt DateTime @default(now())
  quantityG Float?
  name      String
  calories  Float
  protein   Float
  carbs     Float
  fat       Float
  fiber     Float @default(0)
  notes     String?
  createdAt DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodItem FoodItem? @relation(fields: [foodItemId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([foodItemId])
  @@index([consumedAt])
  @@map("meal_logs")
}

model NutritionTarget {
  id        String   @id @default(uuid())
  userId    String   @unique
  calories  Float
  protein   Float
  carbs     Float
  fat       Float
  fiber     Float
  goal      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("nutrition_targets")
}

model HealthDataImport {
  id         String   @id @default(uuid())
  userId     String
  provider   String
  importType String
  status     String
  payload    Json?
  importedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([provider])
  @@index([importedAt])
  @@map("health_data_imports")
}

model WearableConnection {
  id            String   @id @default(uuid())
  userId        String
  provider      String
  status        String
  syncDirection String
  scopes        String[] @default([])
  lastSyncAt    DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
  @@index([provider])
  @@map("wearable_connections")
}

model RecoverySample {
  id                  String   @id @default(uuid())
  userId              String
  provider            String
  recordedAt          DateTime
  hrvMs               Float?
  restingHeartRateBpm Int?
  sleepMinutes        Int?
  activityMinutes     Int?
  readinessScore      Int
  payload             Json?
  createdAt           DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([provider])
  @@index([recordedAt])
  @@map("recovery_samples")
}

model ProductEvent {
  id        String   @id @default(uuid())
  userId     String?
  action    String
  category  String
  source    String?
  metadata  Json?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([category])
  @@index([createdAt])
  @@map("product_events")
}

model NotificationDelivery {
  id          String   @id @default(uuid())
  userId      String
  kind        String
  channel     String
  status      String
  subject     String
  body        String
  href        String?
  dedupeKey   String   @unique
  metadata    Json?
  scheduledFor DateTime
  sentAt      DateTime?
  openedAt    DateTime?
  clickedAt   DateTime?
  failureReason String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([scheduledFor])
  @@index([createdAt])
  @@map("notification_deliveries")
}

model UserNutritionBalance {
  id               String   @id @default(uuid())
  userId           String   @unique
  carryoverCalories Float   @default(0)
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_nutrition_balances")
}

// ==========================================
// MODELOS DE GAMIFICACIÓN
// ==========================================

model UserGamification {
  id             String    @id @default(uuid())
  userId         String    @unique
  xp             Int       @default(0)
  level          Int       @default(1)
  currentStreak  Int       @default(0)
  longestStreak  Int       @default(0)
  lastActivityAt DateTime?
  updatedAt      DateTime  @updatedAt

  // Relaciones
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_gamification")
}

model Achievement {
  id        String @id @default(uuid())
  key       String @unique // "first_workout", "streak_7", "log_100_meals"
  nameEs    String
  nameEn    String
  descEs    String
  descEn    String
  icon      String // nombre de icono Lucide
  xpReward  Int
  condition Json   // condición legible por máquina para desbloqueo

  // Relaciones
  users UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  id            String   @id @default(uuid())
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  // Relaciones
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId])
  @@index([userId])
  @@map("user_achievements")
}

model XPEvent {
  id        String   @id @default(uuid())
  userId    String
  action    String   // "complete_workout", "log_meal", "hit_streak_7"
  xp        Int
  createdAt DateTime @default(now())

  // Relaciones
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
  @@map("xp_events")
}
