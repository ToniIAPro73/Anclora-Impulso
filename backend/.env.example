# Database (REQUERIDO)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# JWT
# Para generar secrets seguros en PowerShell:
#   [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(64))
JWT_SECRET=""
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET=""
JWT_REFRESH_EXPIRES_IN="30d"

# Server
PORT=3001
NODE_ENV="development"

# CORS
FRONTEND_URL="http://localhost:3000,http://127.0.0.1:3000"

# Email notifications (opcional)
SMTP_HOST=""
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM=""
NOTIFICATION_DISPATCH_INTERVAL_MINUTES=15

# LLM - Groq (opcional, para generación de entrenamientos y nutrición con IA)
# Crea tu cuenta gratuita en https://console.groq.com → API Keys
LLM_PROVIDER="groq"
LLM_COACH_ENABLED=false
LLM_COACH_MAX_PROMPT_CHARS=6000
LLM_COACH_MAX_OUTPUT_TOKENS=450
LLM_COACH_MEMORY_MESSAGES=8
LLM_COACH_CACHE_TTL_SECONDS=300
LLM_COACH_WINDOW_MINUTES=60
LLM_COACH_WINDOW_LIMIT=20
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
GROQ_MODEL_PRIMARY="openai/gpt-oss-20b"
GROQ_MODEL_FALLBACK="llama-3.3-70b-versatile"
GROQ_MODEL_FAST="llama-3.1-8b-instant"
GROQ_MODEL_NO_EVIDENCE="llama-3.1-8b-instant"
GROQ_MODEL_GUARD="llama-3.1-8b-instant"

# Admin (opcional, lista separada por comas)
ADMIN_EMAILS=""

# OpenAI (deprecated - reemplazado por Groq)
# OPENAI_API_KEY=""
