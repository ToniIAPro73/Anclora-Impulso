# Database (REQUERIDO)
DATABASE_URL="postgresql://user:password@host:5432/database?sslmode=require"

# JWT
# Para generar secrets seguros en PowerShell:
#   [System.Convert]::ToBase64String([System.Security.Cryptography.RandomNumberGenerator]::GetBytes(64))
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-this-in-production"
JWT_REFRESH_EXPIRES_IN="30d"

# Server
PORT=3001
NODE_ENV="development"

# CORS
FRONTEND_URL="http://localhost:3000"

# LLM - Groq (opcional, para generación de entrenamientos y nutrición con IA)
# Crea tu cuenta gratuita en https://console.groq.com → API Keys
LLM_PROVIDER="groq"
GROQ_API_KEY=""
# GROQ_MODEL="llama-3.3-70b-versatile"
GROQ_MODEL_PRIMARY="openai/gpt-oss-20b"
GROQ_MODEL_FALLBACK="llama-3.3-70b-versatile"
GROQ_MODEL_FAST="llama-3.1-8b-instant"
GROQ_MODEL_NO_EVIDENCE="llama-3.1-8b-instant"
GROQ_MODEL_GUARD="llama-3.1-8b-instant"

# OpenAI (deprecated - reemplazado por Groq)
# OPENAI_API_KEY="sk-..."
